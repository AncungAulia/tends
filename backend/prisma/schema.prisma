// Tends — AI-managed RWA yield aggregator on Mantle.
// Per-user-vault architecture (1 user = 1 UserVault). See backend/INTEGRATION.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: pooled connection (Supabase Supavisor / pgBouncer, port 6543,
  // append ?pgbouncer=true). directUrl: direct connection (port 5432) used only
  // by `prisma migrate deploy` / introspection — pgBouncer can't run migrations.
  // On a non-pooled Postgres, set DIRECT_URL to the same value as DATABASE_URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  walletAddress String   @id
  privyId       String?  @unique
  name          String?
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @updatedAt
  preferences   Json? // client UI prefs (theme, etc.) — cross-device sync

  vault        Vault?
  chatMessages ChatMessage[]
}

/// One ERC-4626 UserVault per user (deployed via VaultFactory). Folds position +
/// allocation: holds shares/initialDeposit and the risk config the agent reads.
model Vault {
  address        String   @id // vault contract address
  owner          String   @unique // User.walletAddress
  riskPreference Int      @default(1) // 0=LOW 1=MEDIUM 2=HIGH 3=CUSTOM
  lowBps         Int? // CUSTOM only
  medBps         Int?
  highBps        Int?
  shares         Decimal  @default(0) @db.Decimal(78, 0)
  initialDeposit Decimal  @default(0) @db.Decimal(78, 0)
  deployedBlock  BigInt?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [owner], references: [walletAddress], onDelete: Cascade)
}

model ChatMessage {
  id            BigInt   @id @default(autoincrement())
  walletAddress String
  role          String // 'user' | 'assistant'
  content       String
  metadata      Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@index([walletAddress, createdAt])
}

/// Time-series of per-asset APY (derived from price growth, or estimate fallback).
model ApyHistory {
  asset      String
  apy        Decimal  @db.Decimal(10, 4)
  snapshotAt DateTime @default(now())

  @@id([asset, snapshotAt])
  @@index([asset, snapshotAt])
}

/// Raw 18-dec USD price snapshots — the basis for realized-APY derivation.
model PriceSnapshot {
  asset      String
  priceWad   String // 18-decimal price as a base-10 string
  snapshotAt DateTime @default(now())

  @@id([asset, snapshotAt])
  @@index([asset, snapshotAt])
}

/// Mirror of on-chain AgentActivityLog + agent decisions made off-chain.
model AgentActivity {
  id           BigInt   @id @default(autoincrement())
  vaultAddress String? // null for global actions (e.g. price pushes)
  action       String // REBALANCE | PRICE_UPDATE | DEPOSIT | WITHDRAW | PAUSE | ALERT
  metadata     Json
  txHash       String?
  blockNumber  BigInt?
  agentAddress String
  timestamp    DateTime

  @@index([vaultAddress, timestamp])
  @@index([txHash])
}

model GasTopUp {
  id        BigInt   @id @default(autoincrement())
  recipient String
  amount    String // wei as string
  txHash    String
  timestamp DateTime @default(now())

  @@index([recipient, timestamp])
}

/// Indexer cursor — last fully-processed block per scope, for idempotent restarts.
model IndexerState {
  key       String   @id // e.g. "factory" or "vault:0x..."
  lastBlock BigInt
  updatedAt DateTime @updatedAt
}

/// Per-user agent guardrails / settings (the FE "Agent" page). One row per vault.
/// The autonomous rebalancer reads these before acting; the chat agent reads `notes`
/// (+ guardrails) for personalized, guardrail-aware advice.
model AgentConfig {
  vaultAddress         String   @id
  autoRebalanceEnabled Boolean  @default(true) // off-chain pause toggle for the auto-agent
  cadenceSec           Int? // off-chain min seconds between rebalances (null = use on-chain only)
  driftThresholdBps    Int? // only rebalance if drift exceeds this % of portfolio (null = dust floor)
  maxSlippageBps       Int      @default(100) // swap slippage tolerance
  perTokenCapsBps      Json? // { "sUSDe": 4000, ... } hard cap per token in bps (null = none)
  perTokenBandsBps     Json? // { "cmETH": { "min": 2000, "max": 3000 } } drift band per token; out-of-band → rebalance
  notes                String? // free-text the chat agent reads for personalization
  maxPerAssetPct       Int? // global max allocation per token (%, null = default 50)
  dailyLimitPerDay     Int? // max rebalances per day (null = no limit)
  stopLossEnabled      Boolean  @default(false)
  stopLossPct          Int? // e.g. 10 = exit if -10%; null when disabled
  updatedAt            DateTime @updatedAt
}

/// Per-step workflow log — emitted by agentLogEmitter during Hermes runs.
/// Persists each step's final outcome (done/skip/error) for historical display.
/// Live "running" status events are SSE-only (not stored here).
model AgentLog {
  id           String   @id @default(uuid())
  vaultAddress String
  workflow     String // e.g. "hermes-rebalancer"
  step         String // e.g. "scan-vault", "signal-market", "decide-allocation", "exec-rebalance"
  status       String // "done" | "skip" | "error"
  message      String
  data         Json?
  ts           DateTime @default(now())

  @@index([vaultAddress, ts])
}

/// Per-vault value-over-time — powers the FE PnL chart. Stores UserVault.totalAssets()
/// (USDC base units, 6-dec) on a schedule; PnL = totalAssets − Vault.initialDeposit.
/// Same valuation basis the dashboard uses for the current value, so the chart and the
/// live PnL number stay consistent.
model VaultSnapshot {
  vaultAddress String
  totalAssets  Decimal  @db.Decimal(78, 0) // raw UserVault.totalAssets()
  snapshotAt   DateTime @default(now())

  @@id([vaultAddress, snapshotAt])
  @@index([vaultAddress, snapshotAt])
}
