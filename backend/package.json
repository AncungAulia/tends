{
  "name": "tends-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-managed RWA yield aggregator on Mantle — backend (API + Hermes Agent integration + indexer)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "studio": "mastra dev",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage \"src/**/*.test.ts\"",
    "verify:chain": "tsx scripts/verify-chain.ts",
    "mcp": "tsx src/mcp/server.ts",
    "relayer:once": "tsx scripts/run-relayer.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@hono/node-server": "^1.13.7",
    "@mastra/core": "^1.40.0",
    "@mastra/memory": "^1.20.2",
    "@mastra/observability": "^1.14.1",
    "@mastra/pg": "^1.12.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@prisma/client": "^6.1.0",
    "@redstone-finance/sdk": "^0.9.0",
    "ethers": "^6.13.4",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "jose": "^6.2.3",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "viem": "^2.21.54",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "mastra": "^1.12.2",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
