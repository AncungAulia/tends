# Env for the Hermes gateway service (separate from the backend service).
# The MCP subprocess (node dist/mcp/server.js) inherits these too.

# ── Hermes API server (must match the backend's HERMES_API_KEY) ──────────────
API_SERVER_ENABLED=true
API_SERVER_KEY=change-me-shared-with-backend
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
# API server is internal-only + key-protected; allow the server-to-server caller.
GATEWAY_ALLOW_ALL_USERS=true

# ── LLM provider: OpenRouter ─────────────────────────────────────────────────
# config.yaml sets provider: openrouter, default: openai/gpt-4o-mini. Hermes reads
# the key from this env var. Get one at openrouter.ai → Keys.
OPENROUTER_API_KEY=sk-or-...

# ── Needed by the MCP server subprocess (same values as the backend) ─────────
DATABASE_URL=postgresql://...
CHAIN_ID=5003
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
USE_MOCK_CONTRACTS=false
VAULT_FACTORY_ADDRESS=0x279B31B00F64C0ce85BCe2Bd7e377CdcAE58d400
PRICE_FEED_ADDRESS=0x7F37687840d238fBE7Ff2E66AD9ed458fa689A2A
ACTIVITY_LOG_ADDRESS=0x864f888330821b6025b2FE670f30E01Ee8776449
STRATEGY_ROUTER_ADDRESS=0xb2f36070E6eae3353E8e755172B477DF213ae248
USDC_ADDR=0x29faf6cAFA4BeA1dC7c232f0a1818d4da6b724DD
MUSD_ADDR=0xADA0466303441102cb16F8eC1594C744d603f746
USDY_ADDR=0x0D7766158f14ad7bB82d9FD8A47734e801E3F5B8
