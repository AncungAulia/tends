# ─── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── Database / Cache (match docker-compose.yml) ─────────────────────────────
DATABASE_URL=postgresql://tends:tends@localhost:5432/tends
REDIS_URL=redis://localhost:6379

# ─── Chain (Mantle Sepolia) ──────────────────────────────────────────────────
CHAIN_ID=5003
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_RPC_URL_FALLBACK=

# AGENT_EXECUTOR signs pushPrices() + rebalance(). Its ADDRESS must be authorized
# in the contracts by Axel. Generate a fresh wallet; share only the address.
PRIVATE_KEY_AGENT_EXECUTOR=
# Funds user wallets with MNT for gas (Privy flow).
PRIVATE_KEY_GAS_FUNDER=

# ─── Contracts (per-user-vault; fill from deployments/mantle-sepolia.json) ───
USE_MOCK_CONTRACTS=true
VAULT_FACTORY_ADDRESS=
PRICE_FEED_ADDRESS=
ACTIVITY_LOG_ADDRESS=
STRATEGY_ROUTER_ADDRESS=
# Already live on Mantle Sepolia:
MOCK_ORACLE_ADDRESS=0x26f9178b4082b68D8cC55874D377f9829Fc8C22d

# ─── Token addresses (mocks on testnet) ──────────────────────────────────────
USDC_ADDR=
MUSD_ADDR=
USDY_ADDR=
METH_ADDR=
CMETH_ADDR=
SUSDE_ADDR=
WMNT_ADDR=

# ─── Price relayer (handed off to backend — RELAYER-HANDOFF.md) ──────────────
# Pushes RedStone + Ondo USDY prices into MockOracle, signed by AGENT_EXECUTOR.
# Set true on the always-on server; keep false in dev to avoid auto-pushing.
RELAYER_ENABLED=false
RELAYER_INTERVAL_SEC=3600
REDSTONE_DATA_SERVICE_ID=redstone-primary-prod
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
USDY_ORACLE_ADDRESS=0xA96abbe61AfEdEB0D14a20440Ae7100D9aB4882f

# Rebalance agent loop + price-freshness monitor (always-on jobs on the server)
REBALANCER_ENABLED=false
REBALANCER_INTERVAL_SEC=3600
PRICE_MONITOR_ENABLED=false
PRICE_MONITOR_INTERVAL_SEC=600
INDEXER_ENABLED=false
APY_SCRAPER_ENABLED=false
APY_SCRAPER_INTERVAL_SEC=300

# ─── Hermes Agent (sidecar — `hermes gateway`, OpenAI-compatible) ────────────
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent
OPENROUTER_KEY=
LLM_MODEL=anthropic/claude-sonnet-4.6

# ─── Privy (auth) ─────────────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# SPKI PEM public key (ES256) from Privy dashboard → used to verify access tokens.
PRIVY_VERIFICATION_KEY=
PRIVY_JWT_ISSUER=privy.io

# ─── Pricing / MCP ────────────────────────────────────────────────────────────
COINGECKO_API_KEY=
MCP_PORT=8765
